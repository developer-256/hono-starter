{
    "name": "ecommerce-new-backend",
    "type": "module",
    "version": "1.0.0",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc && tsc-alias",
        "start": "node dist/src/index.js",
        "biome:format": "npx @biomejs/biome format --write ./src",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@hono/node-server": "^1.14.4",
        "@hono/zod-openapi": "^0.19.8",
        "@libsql/client": "^0.15.9",
        "@scalar/hono-api-reference": "^0.9.3",
        "dotenv": "^16.5.0",
        "dotenv-expand": "^12.0.2",
        "drizzle-orm": "^0.44.2",
        "drizzle-zod": "^0.8.2",
        "hono": "^4.7.11",
        "zod": "^3.25.61"
    },
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@types/node": "^20.11.17",
        "drizzle-kit": "^0.31.1",
        "husky": "^9.1.7",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.20.1",
        "typescript": "^5.8.3"
    }
}
